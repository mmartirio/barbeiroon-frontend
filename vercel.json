{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/downloads/:path*", "destination": "https://api-barbeiroon.com.br/downloads/:path*", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*",     "destination": "https://api-barbeiroon.com.br/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://api-barbeiroon.com.br/uploads/:path*" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
