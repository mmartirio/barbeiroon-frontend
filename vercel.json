{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://191.252.228.245:3001/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://191.252.228.245:3001/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
